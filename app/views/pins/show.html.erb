<%= turbo_frame_tag "pin_sidebar" do %>
  <div id="pin-show-sidebar" class="space-y-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="text-sm uppercase tracking-wide text-zinc-500"><%= @pin.kind %></p>
        <h2 class="text-2xl font-semibold"><%= @pin.hood %></h2>
        <p class="mt-1 text-sm text-zinc-500">Reported <%= @pin.reported_on.to_fs(:long) %></p>
      </div>

      <button
        type="button"
        class="rounded-full border border-zinc-700 px-3 py-1 text-sm text-zinc-300"
        data-action="map#closeSidebar"
      >Close</button>
    </div>

    <% if @pin.rent_cents.present? %>
      <p class="text-3xl font-semibold"><%= number_to_currency(@pin.rent_cents / 100.0, precision: 0) %></p>
    <% end %>

    <section class="grid grid-cols-2 gap-3 text-sm">
      <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-4">
        <p class="text-zinc-500">Bedrooms</p>
        <p class="mt-1 font-medium"><%= @pin.bedrooms.nil? ? "Unknown" : @pin.bedrooms %></p>
      </div>

      <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-4">
        <p class="text-zinc-500">Square feet</p>
        <p class="mt-1 font-medium"><%= @pin.square_feet.presence || "Unknown" %></p>
      </div>

      <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-4">
        <p class="text-zinc-500">Move-in year</p>
        <p class="mt-1 font-medium"><%= @pin.move_in_year.presence || "Unknown" %></p>
      </div>

      <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-4">
        <p class="text-zinc-500">Listed rent</p>
        <p class="mt-1 font-medium">
          <%= @pin.listed_rent_cents.present? ? number_to_currency(@pin.listed_rent_cents / 100.0, precision: 0) : "Unknown" %>
        </p>
      </div>
    </section>

    <% if @pin.building.present? %>
      <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-4">
        <p class="text-sm text-zinc-500">Building</p>
        <p class="font-medium"><%= @pin.building.display_name.presence || "#{@pin.building.street_number} #{@pin.building.street}" %></p>
        <p class="text-sm text-zinc-400"><%= @pin.building.street_number %> <%= @pin.building.street %></p>
        <p class="text-sm text-zinc-400"><%= @pin.building.city %>, <%= @pin.building.state %> <%= @pin.building.postal_code %></p>
      </div>
    <% end %>

    <section class="rounded-2xl border border-zinc-800 bg-zinc-900 p-4">
      <p class="text-sm text-zinc-500">Location</p>
      <p class="mt-1 font-medium"><%= @pin.locality.name %></p>
      <p class="text-sm text-zinc-400"><%= @pin.latitude.to_f %>, <%= @pin.longitude.to_f %></p>
    </section>

    <% if @pin.note.present? %>
      <p class="leading-7 text-zinc-300"><%= @pin.note %></p>
    <% end %>

    <section class="space-y-3">
      <h3 class="font-semibold">Details</h3>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between gap-4 border-b border-zinc-800 pb-2">
          <dt class="text-zinc-500">Source</dt>
          <dd class="text-right"><%= @pin.source.presence || "Unknown" %></dd>
        </div>
        <div class="flex justify-between gap-4 border-b border-zinc-800 pb-2">
          <dt class="text-zinc-500">Broker fee</dt>
          <dd class="text-right"><%= @pin.broker_fee_cents.present? ? number_to_currency(@pin.broker_fee_cents / 100.0, precision: 0) : "Unknown" %></dd>
        </div>
        <div class="flex justify-between gap-4 border-b border-zinc-800 pb-2">
          <dt class="text-zinc-500">Parking included</dt>
          <dd class="text-right"><%= @pin.parking_included? ? "Yes" : "No" %></dd>
        </div>
        <div class="flex justify-between gap-4 border-b border-zinc-800 pb-2">
          <dt class="text-zinc-500">Utilities included</dt>
          <dd class="text-right"><%= @pin.utilities_included? ? "Yes" : "No" %></dd>
        </div>
        <div class="flex justify-between gap-4 border-b border-zinc-800 pb-2">
          <dt class="text-zinc-500">Rent controlled</dt>
          <dd class="text-right"><%= @pin.rent_controlled? ? "Yes" : "No" %></dd>
        </div>
        <div class="flex justify-between gap-4 border-b border-zinc-800 pb-2">
          <dt class="text-zinc-500">Rent stabilized</dt>
          <dd class="text-right"><%= @pin.rent_stabilized? ? "Yes" : "No" %></dd>
        </div>
        <div class="flex justify-between gap-4 pb-2">
          <dt class="text-zinc-500">Submitted by</dt>
          <dd class="text-right"><%= @pin.user.email_address %></dd>
        </div>
      </dl>
    </section>

    <% if @pin.tags.present? %>
      <section class="space-y-3">
        <h3 class="font-semibold">Tags</h3>
        <div class="flex flex-wrap gap-2">
          <% @pin.tags.split(",").map(&:strip).reject(&:blank?).each do |tag| %>
            <span class="rounded-full bg-zinc-800 px-3 py-1 text-sm text-zinc-300"><%= tag %></span>
          <% end %>
        </div>
      </section>
    <% end %>

    <section class="space-y-3">
      <div class="flex items-center justify-between">
        <h3 class="font-semibold">Comments</h3>
        <span class="text-sm text-zinc-500"><%= @pin.comments_count %></span>
      </div>

      <% if @pin.comments.any? %>
        <div class="space-y-3">
          <% @pin.comments.each do |comment| %>
            <article class="rounded-2xl border border-zinc-800 bg-zinc-900 p-4">
              <div class="flex items-center justify-between gap-4 text-sm">
                <p class="font-medium"><%= comment.relationship.presence || "Resident" %></p>
                <p class="text-zinc-500"><%= comment.created_at.to_date.to_fs(:medium) %></p>
              </div>
              <% if comment.body.present? %>
                <p class="mt-3 leading-6 text-zinc-300"><%= comment.body %></p>
              <% end %>
              <p class="mt-3 text-xs text-zinc-500"><%= comment.user.email_address %></p>
            </article>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-zinc-500">No comments yet.</p>
      <% end %>
    </section>

    <section class="space-y-3">
      <div class="flex items-center justify-between">
        <h3 class="font-semibold">Flags</h3>
        <span class="text-sm text-zinc-500"><%= @pin.flags_count %></span>
      </div>

      <% if @pin.pin_flags.any? %>
        <div class="space-y-2">
          <% @pin.pin_flags.each do |flag| %>
            <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-4 text-sm">
              <p class="font-medium"><%= flag.reason.humanize %></p>
              <p class="mt-1 text-zinc-500"><%= flag.user.email_address %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-zinc-500">No flags.</p>
      <% end %>
    </section>
  </div>
<% end %>
